{
    "name": "servicioslineaonce/starter-kit",
    "description": "Servicio Linea Once starter kit for Laravel, Inertia, Vue, React, MUI, PrimeVue, Ziggy, and Tailwind CSS.",
    "version": "1.0.0",
    "type": "library",
    "keywords": [
        "laravel",
        "starter-kit",
        "inertia",
        "livewire",
        "primevue",
        "naive-ui",
        "react",
        "wireui",
        "tailwindcss"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "bacon/bacon-qr-code": "^3.1",
        "illuminate/console": "^13.0",
        "illuminate/filesystem": "^13.0",
        "illuminate/support": "^13.0",
        "pragmarx/google2fa": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "ServiciosLineaOnce\\StarterKit\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ServiciosLineaOnce\\StarterKit\\StarterKitServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
